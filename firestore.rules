rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Financial fields are managed exclusively by the server via Admin SDK — never by the client
      allow update: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['balance', 'totalDeposited', 'totalWithdrawn', 'totalEarned',
                    'commissionBalance', 'totalCommissionEarned', 'referralCount', 'referredBy']);
      // New user doc creation (registration / ensureUserDoc) — balance must start at 0
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.balance == 0;
    }

    // ── Bots ─────────────────────────────────────────────────────────────────
    match /bots/{botId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // ── Matches ───────────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if request.auth != null &&
        (resource.data.player1Uid == request.auth.uid ||
         resource.data.player2Uid == request.auth.uid);
      allow create: if request.auth != null;
    }

    // ── Withdrawals (legacy — keep for backward compat) ───────────────────────
    match /withdrawals/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // ── Transactions ──────────────────────────────────────────────────────────
    // Created and updated exclusively by Admin SDK (server).
    // Client can only read their own transaction docs (for polling deposit status).
    match /transactions/{txId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }
  }
}
