rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    // Only the authenticated owner can read/write their own doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Bots ─────────────────────────────────────────────────────────────────
    // Any authenticated user can read bots. Only anonymous seed script can write.
    match /bots/{botId} {
      allow read: if request.auth != null;
      // Temporarily allow write for anonymous seeding — tighten after seed.
      allow write: if request.auth != null && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // ── Matches ───────────────────────────────────────────────────────────────
    // Players can read their own matches. Server (or client) creates records.
    match /matches/{matchId} {
      allow read: if request.auth != null &&
        (resource.data.player1Uid == request.auth.uid ||
         resource.data.player2Uid == request.auth.uid);
      allow create: if request.auth != null;
    }

    // ── Withdrawals ───────────────────────────────────────────────────────────
    // Users can create and read their own withdrawal requests.
    match /withdrawals/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }
  }
}
